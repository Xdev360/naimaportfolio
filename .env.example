# Your WhatsApp number (international format, no + or spaces)
WHATSAPP_PHONE=2348088141633

# CallMeBot WhatsApp — use the CURRENT bot number: +34 644 95 73 56
# 1. Save that number as "CallMeBot" in your contacts
# 2. WhatsApp message to it: I allow callmebot to send me messages
# 3. Paste the API key CallMeBot replies with:
CALLMEBOT_API_KEY=

# Optional backup (works instantly, no flaky activation):
# 1. Telegram → message @BotFather → /newbot → copy token
# 2. Message your new bot once, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3. Copy your chat id from the response:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
